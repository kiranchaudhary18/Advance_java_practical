pipeline {
    agent any

    tools {
        // Updated based on your Jenkins configuration
        maven 'maven3'
        jdk 'jdk21' 
    }

    stages {
        stage('Checkout from GitHub') {
            steps {
                echo 'Checking out the project from GitHub...'
                // Using the root repository URL.
                git branch: 'main', url: 'https://github.com/ArjunDivraniya/Sem-4-Paractical.git'
                echo 'GitHub Checkout completed successfully!'
            }
        }

        stage('Clean Workspace') {
            steps {
                dir('DevOOPS/to-do') {
                    echo 'Cleaning up the workspace...'
                    // Make mvnw executable and run it
                    sh 'chmod +x mvnw'
                    sh './mvnw clean'
                    echo 'Workspace is clean!'
                }
            }
        }

        stage('Build') {
            steps {
                dir('DevOOPS/to-do') {
                    echo 'Compiling the application...'
                    sh './mvnw compile'
                    echo 'Build completed successfully!'
                }
            }
        }

        stage('Test') {
            steps {
                dir('DevOOPS/to-do') {
                    echo 'Running unit tests...'
                    sh './mvnw test'
                    echo 'All tests passed successfully!'
                }
            }
        }

        stage('Package') {
            steps {
                dir('DevOOPS/to-do') {
                    echo 'Packaging the application into a JAR file...'
                    sh './mvnw package -DskipTests'
                    echo 'Packaging completed successfully!'
                }
            }
        }

        stage('Run Application') {
            steps {
                dir('DevOOPS/to-do') {
                    echo 'Starting the Spring Boot application on EC2...'
                    // First, stop any existing running application on port 8082
                    sh 'fuser -k 8082/tcp || true'
                    
                    // Run the packaged JAR in the background and prevent Jenkins from waiting/killing it
                    sh 'JENKINS_NODE_COOKIE=dontKillMe nohup java -jar target/to-do-0.0.1-SNAPSHOT.jar > app.log 2>&1 &'
                    echo 'Application started in background! Pipeline will now finish.'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution finished.'
        }
        success {
            echo 'SUCCESS: The Spring Boot To-Do application built successfully.'
        }
        failure {
            echo 'FAILED: The build failed. Please check the logs.'
        }
    }
}
